POSTGRES_USER=codecmp
POSTGRES_PASSWORD=codecmp
POSTGRES_DB=codecmp

# When running outside docker, use these host-mapped ports:
# DATABASE_URL=postgresql+asyncpg://codecmp:codecmp@localhost:5433/codecmp
# REDIS_URL=redis://localhost:6380/0
# Inside docker, services communicate via container names:
DATABASE_URL=postgresql+asyncpg://codecmp:codecmp@postgres:5432/codecmp
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

UPLOAD_DIR=/repos
MAX_UPLOAD_SIZE_MB=500

# Frontend
VITE_API_URL=http://localhost:8000
